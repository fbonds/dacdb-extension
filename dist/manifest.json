{
  "manifest_version": 3,
  "name": "DACdb CSV Export",
  "version": "0.1.0",
  "description": "Export any table on DACdb to CSV",
  "permissions": [],
  "host_permissions": ["https://*.dacdb.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon-48.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.dacdb.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "all_frames": true
    }
  ]
}